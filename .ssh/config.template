# SSH Config Template — copy to ~/.ssh/config and fill in details
# Run: chmod 600 ~/.ssh/config

Host *
    ServerAliveInterval 60
    ServerAliveCountMax 3
    AddKeysToAgent yes
    IdentityFile ~/.ssh/id_ed25519

# Example: jump host
# Host bastion
#     HostName bastion.example.com
#     User ubuntu
#     IdentityFile ~/.ssh/id_ed25519

# Example: host through jump
# Host internal
#     HostName 10.0.0.1
#     User ubuntu
#     ProxyJump bastion
